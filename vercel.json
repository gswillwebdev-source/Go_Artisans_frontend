{
    "buildCommand": "npm run vercel-build-full",
    "installCommand": "npm install; npm --prefix frontend install; npm --prefix frontend/frontend install; npm --prefix frontend/frontend/frontend install",
    "crons": [
        {
            "path": "/api/cron/send-emails",
            "schedule": "0 9 * * *"
        },
        {
            "path": "/api/cron/process-trials",
            "schedule": "0 0 * * *"
        },
        {
            "path": "/api/cron/reset-monthly",
            "schedule": "0 0 1 * *"
        }
    ]
}